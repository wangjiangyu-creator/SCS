---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageLead from "../components/PageLead.astro";
import ResourceExplorer from "../components/ResourceExplorer.astro";
import sources from "../data/sources.json";

const literatureTypes = new Set([
  "Academic Publication",
  "Book",
  "Book Chapter",
  "Journal Article",
  "Legal Study",
  "Thesis",
  "Working Paper"
]);

const sortByYearDesc = (items: typeof sources) =>
  [...items].sort((a, b) => b.year - a.year || a.title.localeCompare(b.title));

const literatureSources = sources.filter(
  (source) => source.topics.includes("Literature") || literatureTypes.has(source.sourceType)
);

const chineseWorks = sortByYearDesc(
  literatureSources.filter((source) => source.topics.includes("Chinese works"))
);

const englishWorks = sortByYearDesc(
  literatureSources.filter((source) => !source.topics.includes("Chinese works"))
);

const books = literatureSources.filter((source) => source.sourceType === "Book").length;
const articlesAndPapers = literatureSources.filter((source) =>
  ["Academic Publication", "Book Chapter", "Journal Article", "Working Paper", "Legal Study"].includes(source.sourceType)
).length;

const authorIncludes = (source: (typeof sources)[number], names: string[]) =>
  names.some((name) => source.authors.join(" ").toLowerCase().includes(name.toLowerCase()));

const focusClusters = [
  {
    label: "Jiangyu Wang / 王江雨",
    description: "Scholarship and commentary by Jiangyu Wang on the arbitration, Chinese perspectives, and international-law framing.",
    items: sortByYearDesc(
      literatureSources.filter((source) => authorIncludes(source, ["Jiangyu Wang", "王江雨"]))
    )
  },
  {
    label: "Bingbing Jia",
    description: "Works by Bingbing Jia on the nine-dash line, Huangyan/Scarborough Shoal, admissibility, and the arbitration.",
    items: sortByYearDesc(
      literatureSources.filter((source) => authorIncludes(source, ["Bingbing Jia", "Bing Bing Jia"]))
    )
  },
  {
    label: "Chinese Journal of International Law",
    description: "CJIL articles, comments, and special-issue materials central to the legal debate over jurisdiction, admissibility, and the awards.",
    items: sortByYearDesc(
      literatureSources.filter((source) => source.issuer === "Chinese Journal of International Law")
    )
  }
];
---

<BaseLayout
  title="Literature"
  description="Academic literature on the South China Sea disputes, divided into English works and Chinese works."
>
  <PageLead
    eyebrow="Academic literature"
    title="Books, journal articles, chapters, working papers, and legal studies on the South China Sea disputes."
    text="This page separates English works and Chinese works while keeping both sets connected to the searchable source library. It includes legal, historical, geopolitical, policy, and dispute-settlement scholarship."
  />

  <section class="metric-row literature-metrics" aria-label="Literature counts">
    <div>
      <strong>{englishWorks.length}</strong>
      <span>English works</span>
    </div>
    <div>
      <strong>{chineseWorks.length}</strong>
      <span>Chinese works</span>
    </div>
    <div>
      <strong>{books}</strong>
      <span>Books and edited volumes</span>
    </div>
    <div>
      <strong>{articlesAndPapers}</strong>
      <span>Articles, chapters, papers, and studies</span>
    </div>
  </section>

  <section class="section-band literature-focus">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Focused clusters</p>
        <h2>Targeted scholar and journal coverage</h2>
      </div>
      <a href={`${import.meta.env.BASE_URL}library/`}>Search all records</a>
    </div>
    <div class="focus-grid">
      {focusClusters.map((cluster) => (
        <article class="focus-card">
          <div class="focus-card-topline">
            <h3>{cluster.label}</h3>
            <strong>{cluster.items.length}</strong>
          </div>
          <p>{cluster.description}</p>
          <ul>
            {cluster.items.slice(0, 6).map((item) => (
              <li>
                <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
                <span>{item.year}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section-band literature-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">English works</p>
        <h2>English-language scholarship and research literature</h2>
      </div>
      <a href={`${import.meta.env.BASE_URL}library/`}>Open full library</a>
    </div>
    <ResourceExplorer resources={englishWorks} compact />
  </section>

  <section class="section-band literature-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Chinese works</p>
        <h2>中文学术文献与研究成果</h2>
      </div>
      <a href={`${import.meta.env.BASE_URL}library/`}>Open full library</a>
    </div>
    <ResourceExplorer resources={chineseWorks} compact />
  </section>
</BaseLayout>
