---
import { navItems } from "../data/site";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const currentPath = Astro.url.pathname;
const linkFor = (href: string) => `${base}${href}`;
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={base} aria-label="South China Sea Disputes dashboard">
      <span class="brand-mark">SCS</span>
      <span>
        <strong>South China Sea</strong>
        <small>Legal and policy briefing</small>
      </span>
    </a>
    <nav class="main-nav" aria-label="Main navigation">
      {navItems.map((item) => {
        const href = linkFor(item.href);
        const active = currentPath === href || (item.href && currentPath.startsWith(href));
        return (
          <a href={href} aria-current={active ? "page" : undefined}>
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
